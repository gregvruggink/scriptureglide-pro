{
  "$schema": "../../node_modules/@tauri-apps/cli/config.schema.json#capability",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main",
    "presentation"
  ],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:webview:default",
    "core:window:allow-set-fullscreen",
    "core:window:allow-set-decorations",
    "updater:default",
    "dialog:default",
    "process:default",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-exists",
    "fs:allow-read",
    "fs:allow-write",
    "fs:allow-app-cache-recursive",
    "fs:allow-app-config-recursive",
    "fs:allow-app-data-recursive",
    "fs:allow-app-local-data-recursive",
    "fs:allow-app-log-recursive",
    "fs:allow-desktop-recursive",
    "fs:allow-documents-recursive",
    "fs:allow-downloads-recursive",
    "fs:allow-home-recursive",
    "fs:allow-video-recursive",
    "fs:allow-picture-recursive",
    "fs:allow-public-recursive",
    "fs:allow-temp-recursive",
    "fs:allow-template-recursive",
    {
      "identifier": "state-commands",
      "commands": [
        "get_state",
        "set_state",
        "open_presentation_window",
        "close_presentation_window",
        "list_monitors"
      ]
    }
  ]
}
