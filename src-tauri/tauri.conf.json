{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ScriptureGlide Pro",
  "version": "0.1.0",
  "identifier": "com.scriptureglide.pro",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ScriptureGlide Pro",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://raw.githubusercontent.com/gregvruggink/scriptureglide/main/update.json"
      ],
      "pubkey": "RWSn8PtLaxCAehsgRM/1qujfw9rC+wsadZBh4xPdYAkWeyELJ+Jr2vtv"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
