{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ScriptureGlide Pro",
  "version": "0.1.0",
  "identifier": "com.scriptureglide.pro",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ScriptureGlide Pro",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https: http: data: blob: https://asset.localhost; video-src 'self' asset: https: http: data: blob: https://asset.localhost; connect-src 'self' https: http: localhost:3000 http://localhost:3000 https://api.esv.org https://api.codetabs.com https://bolls.life https://bible.helloao.org https://bible-api.com; style-src 'self' 'unsafe-inline' https:; font-src 'self' https: data:; script-src 'self' 'unsafe-inline' 'unsafe-eval'",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    },
    "withGlobalTauri": true
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://raw.githubusercontent.com/gregvruggink/scriptureglide/main/update.json"
      ],
      "pubkey": "RWSn8PtLaxCAehsgRM/1qujfw9rC+wsadZBh4xPdYAkWeyELJ+Jr2vtv"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
